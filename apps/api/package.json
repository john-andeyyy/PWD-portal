{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "pnpm exec node dist/main",
    "start:dev": "pnpm exec nest start --watch",
    "build": "pnpm exec prisma generate --schema=../../prisma/schema.prisma && pnpm exec nest build",
    "lint": "pnpm exec eslint \"src/**/*.{ts,js}\" --fix",
    "seed": "pnpm exec ts-node ../../prisma/seed.ts"
  },
  "prisma": {
    "schema": "../../prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.4",
    "@nestjs/core": "^10.3.4",
    "@nestjs/jwt": "^10.1.0",
    "@nestjs/passport": "^10.0.2",
    "@nestjs/platform-express": "^10.3.4",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.15.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.4",
    "@nestjs/schematics": "^10.0.3",
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.20",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^3.0.8",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}

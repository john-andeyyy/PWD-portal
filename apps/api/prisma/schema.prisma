generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id          String      @id @default(uuid())
  name        String      @unique
  permissions String[]    @default([])
  createdAt   DateTime    @default(now())
  presidents  President[]

  @@map("roles")
}

model President {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  password     String
  isEnabled    Boolean  @default(true)
  isSuperAdmin Boolean  @default(false)
  roleId       String?
  role         Role?    @relation(fields: [roleId], references: [id])
  memberId     String?  @unique
  member       Member?  @relation("PresidentProfile", fields: [memberId], references: [id])
  createdAt    DateTime @default(now())
  addedMembers Member[] @relation("MembersAddedByPresident")

  @@map("presidents")
}

model Member {
  id               String     @id @default(uuid())
  addedById        String     @map("presidentId")
  fname            String
  lname            String
  mname            String?
  bday             DateTime
  disability       String
  phoneNumber      String
  address          String
  barangay         String
  isBedridden      Boolean
  pwdId            String     @unique
  dateIssued       DateTime?
  gender           String
  joinedAt         DateTime   @default(now())
  addedBy          President  @relation("MembersAddedByPresident", fields: [addedById], references: [id])
  presidentProfile President? @relation("PresidentProfile")

  @@map("members")
}

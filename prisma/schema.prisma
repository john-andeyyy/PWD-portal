generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model President {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  members   Member[]
}

model Member {
  id          Int       @id @default(autoincrement())
  presidentId Int
  name        String
  email       String    @unique
  phone       String?
  role        String?
  joinedAt    DateTime  @default(now())
  president   President @relation(fields: [presidentId], references: [id])
}
